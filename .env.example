VITE_APP_URL=https://your-production-domain.example

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_PHOTOS_BUCKET=cargo-photos

VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-firebase-auth-domain
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-firebase-storage-bucket
VITE_FIREBASE_MESSAGING_SENDER_ID=your-firebase-messaging-sender-id
VITE_FIREBASE_APP_ID=your-firebase-app-id
VITE_FIREBASE_VAPID_KEY=your-firebase-web-push-vapid-key

VITE_PAYMONGO_PUBLIC_KEY=your-paymongo-public-key

# Local deployment/admin helper only. Do not expose this in browser builds.
supabase_PAT=your-supabase-personal-access-token

# Supabase Edge Function secrets, not Vite/browser env vars:
# PAYMONGO_SECRET_KEY
# FIREBASE_SERVICE_ACCOUNT_B64
# SUPABASE_SERVICE_ROLE_KEY
